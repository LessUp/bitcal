# EditorConfig - https://editorconfig.org
# This file helps maintain consistent coding style across different editors and IDEs

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C++ source files
[*.{cpp,hpp,h,c,cc,cxx}]
indent_size = 4

# CMake files
[CMakeLists.txt]
indent_size = 2

[*.cmake]
indent_size = 2

# Makefile
[Makefile]
indent_style = tab

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Batch files (Windows)
[*.bat]
end_of_line = crlf

# Python files
[*.py]
indent_size = 4
